	pmid = {39788104},
	pmcid = {PMC11770232},
	keywords = {Chromatin, chromatin accessibility, Humans, Quantitative Trait Loci, Genome-Wide Association Study, Female, Male, Genetic Predisposition to Disease, Adult, eQTL, 3D chromatin structure, Aged, Cartilage, Articular, chondrocyte, Chondrocytes, colocalization, Middle Aged, Osteoarthritis},
	pages = {100738},
	file = {Full Text PDF:/Users/yurikoharigaya/Zotero/storage/CQT99XTK/Kramer et al. - 2025 - Response eQTLs, chromatin accessibility, and 3D chromatin structure in chondrocytes provide mechanis.pdf:application/pdf},
